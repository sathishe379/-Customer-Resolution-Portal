FROM mcr.microsoft.com/dotnet/aspnet:10.0 AS base
WORKDIR /app
EXPOSE 80

FROM mcr.microsoft.com/dotnet/sdk:10.0 AS build
WORKDIR /src
COPY ["CustomerResolutionApi/CustomerResolutionApi.csproj", "CustomerResolutionApi/"]
RUN dotnet restore "CustomerResolutionApi/CustomerResolutionApi.csproj"
COPY CustomerResolutionApi/ CustomerResolutionApi/
WORKDIR "/src/CustomerResolutionApi"
RUN dotnet build -c Release -o /app/build

FROM build AS publish
RUN dotnet publish -c Release -o /app/publish /p:UseAppHost=false

FROM base AS final
WORKDIR /app
COPY --from=publish /app/publish .
ENTRYPOINT ["dotnet", "CustomerResolutionApi.dll"]
